{
  "name": "html-to-pdf",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --watch",
    "test": "HOST=127.0.0.1 PORT=3334 node ace test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#schemas/*": "./app/schemas/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#database/*": "./database/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#start/*": "./start/*.js",
    "#tests/*": "./tests/*.js",
    "#config/*": "./config/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/api-client": "^3.2.1",
    "@japa/assert": "^4.0.1",
    "@japa/plugin-adonisjs": "^5.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/node": "^24.12.2",
    "eslint": "^10.2.0",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "typescript": "^6.0.2",
    "youch": "^4.1.1"
  },
  "dependencies": {
    "@adonisjs/core": "^7.3.1",
    "@adonisjs/drive": "^4.0.0",
    "@adonisjs/limiter": "^3.0.1",
    "@aws-sdk/client-s3": "^3.1020.0",
    "@aws-sdk/s3-request-presigner": "^3.1020.0",
    "@foadonis/openapi": "^1.0.1",
    "@google-cloud/storage": "^7.19.0",
    "@vinejs/vine": "^4.3.1",
    "edge.js": "^6.5.0",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "pdf-to-img": "^6.0.0",
    "playwright": "^1.58.1",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.34.5"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "overrides": {
    "tar": "^7.5.11",
    "minimatch": "^9.0.7",
    "glob": "^10.5.0",
    "cross-spawn": "^7.0.5",
    "brace-expansion": "^2.0.3",
    "picomatch": "^4.0.4",
    "diff": "^5.2.2",
    "lodash-es": "^4.18.1",
    "hono": "^4.12.14",
    "@tootallnate/once": "^3.0.1",
    "http-proxy-agent": "^7.0.2",
    "teeny-request": "^10.1.2"
  },
  "eslintConfig": {
    "extends": "@adonisjs/eslint-config/app"
  },
  "prettier": "@adonisjs/prettier-config"
}
